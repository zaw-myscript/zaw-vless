show_account_table() {
    if [ ! -s "$DB" ]; then echo -e "${R}  ⚠️ အကောင့်မရှိသေးပါ။${Z}"; return 1; fi
    echo -e "  ${C}╔════╦══════════════╦══════════════╦════════════╦═══════╗${Z}"
    echo -e "  ${C}║ ${Y}စဉ်${C} ║ ${Y}အမည်${C}         ║ ${Y}ကုန်ဆုံးရက်${C}    ║ ${Y}အခြေအနေ${C}    ║ ${Y}Limit${C} ║${Z}"
    echo -e "  ${C}╠════╬══════════════╬══════════════╬════════════╬═══════╣${Z}"

    today_date=$(date +"%Y-%m-%d")
    today_sec=$(date -d "$today_date" +%s)
    
    local i=1
    while read -r user uuid exp limit; do
        limit_val=${limit:-1}
        exp_sec=$(date -d "$exp" +%s 2>/dev/null)
        
        if [[ "$exp" == "$today_date" ]]; then
            printf "  ${C}║${Z} ${Y}%-2s${Z} ${C}║${Z} ${Y}%-12s${Z} ${C}║${Z} ${Y}%-12s${Z} ${C}║${Z} ${Y}⚠️ Today  ${C}║${Z} ${Y}%-5s${Z} ${C}║\n" "$i" "$user" "$exp" "$limit_val"
        elif [[ -n "$exp_sec" && $exp_sec -lt $today_sec ]]; then
            printf "  ${C}║${Z} ${R}%-2s${Z} ${C}║${Z} ${R}%-12s${Z} ${C}║${Z} ${R}%-12s${Z} ${C}║${Z} ${R}❌ Expired${C}║${Z} ${R}%-5s${Z} ${C}║\n" "$i" "$user" "$exp" "$limit_val"
        else
            printf "  ${C}║${Z} %-2s ${C}║${Z} %-12s ${C}║${Z} %-12s ${C}║${Z} ${G}✅ Active ${C}║${Z} %-5s ${C}║\n" "$i" "$user" "$exp" "$limit_val"
        fi
        i=$((i+1))
    done < "$DB"
    echo -e "  ${C}╚════╩══════════════╩══════════════╩════════════╩═══════╝${Z}"
