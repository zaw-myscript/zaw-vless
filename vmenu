}

# === 📊 အကောင့်ဇယားကွက်ပြသသည့် စနစ် ===
show_account_table() {
    if [ ! -s "$DB" ]; then echo -e "${R}  ⚠️ အကောင့်မရှိသေးပါ။${Z}"; return 1; fi
    echo -e "  ${C}╔════╦══════════════╦══════════════╦════════════╦═══════╗${Z}"
    echo -e "  ${C}║ ${Y}စဉ်${C} ║ ${Y}အမည်${C}         ║ ${Y}ကုန်ဆုံးရက်${C}    ║ ${Y}အခြေအနေ${C}    ║ ${Y}Limit${C} ║${Z}"
    echo -e "  ${C}╠════╬══════════════╬══════════════╬════════════╬═══════╣${Z}"

    today_date=$(date +"%Y-%m-%d")
    today_sec=$(date -d "$today_date" +%s)
    
    local i=1
    while read -r user uuid exp limit; do
        limit_val=${limit:-1}
        exp_sec=$(date -d "$exp" +%s 2>/dev/null)
        
        if [[ "$exp" == "$today_date" ]]; then
            printf "  ${C}║${Z} ${Y}%-2s${Z} ${C}║${Z} ${Y}%-12s${Z} ${C}║${Z} ${Y}%-12s${Z} ${C}║${Z} ${Y}⚠️ Today  ${C}║${Z} ${Y}%-5s${Z} ${C}║\n" "$i" "$user" "$exp" "$limit_val"
        elif [[ $exp_sec -lt $today_sec ]]; then
            printf "  ${C}║${Z} ${R}%-2s${Z} ${C}║${Z} ${R}%-12s${Z} ${C}║${Z} ${R}%-12s${Z} ${C}║${Z} ${R}❌ Expired${C}║${Z} ${R}%-5s${Z} ${C}║\n" "$i" "$user" "$exp" "$limit_val"
        else
            printf "  ${C}║${Z} %-2s ${C}║${Z} %-12s ${C}║${Z} %-12s ${C}║${Z} ${G}✅ Active ${C}║${Z} %-5s ${C}║\n" "$i" "$user" "$exp" "$limit_val"
        fi
        i=$((i+1))
    done < "$DB"
    echo -e "  ${C}╚════╩══════════════╩══════════════╩════════════╩═══════╝${Z}"
    return 0
}

# (၁) အကောင့်သစ်ဖွင့်ခြင်း
add_user() {
    header
    echo -e "${G}  [+] အကောင့်သစ်ဖန်တီးခြင်း ${Z}\n"
    read -r -p "  ➔ အကောင့်အမည် ထည့်ပါ: " user
    user=$(echo "$user" | sed 's/[^a-zA-Z0-9]//g')
    
    if [[ -z "$user" ]]; then echo -e "${R}  ⚠️ အမည်မှားယွင်းနေပါသည်။${Z}"; pause; return; fi
    if grep -q "^$user " "$DB" 2>/dev/null; then echo -e "${R}  ⚠️ ဤအမည်ရှိပြီးသားပါ။${Z}"; pause; return; fi
    
    read -r -p "  ➔ သက်တမ်း (ရက်) ထည့်ပါ: " days
    days=$(echo "$days" | sed 's/[^0-9]//g')
    if [[ -z "$days" ]]; then echo -e "${R}  ⚠️ ရက်အရေအတွက်မှားယွင်းနေပါသည်။${Z}"; pause; return; fi
    
    read -r -p "  ➔ IP Limit (ဖုန်းဘယ်နှစ်လုံး သုံးခွင့်ပေးမလဲ): " limit
    limit=$(echo "$limit" | sed 's/[^0-9]//g')
    [[ -z "$limit" ]] && limit=1
    
    exp=$(date -d "+$days days" +"%Y-%m-%d" 2>/dev/null)
    uuid=$(cat /proc/sys/kernel/random/uuid 2>/dev/null || uuidgen)
    
    if jq --arg id "$uuid" --arg em "$user" '.inbounds[0].settings.clients += [{"id": $id, "email": $em}]' "$CFG" > tmp.json 2>/dev/null; then
        mv tmp.json "$CFG"
        echo "$user $uuid $exp $limit" >> "$DB"
        systemctl restart xray
        
        link="vless://${uuid}@${IP}:80?type=ws&security=none&path=%2Fzawvless#${user}"
        
        header
        echo -e "${G}  ✅ အကောင့်အောင်မြင်စွာ ဖွင့်ပြီးပါပြီ! ${Z}\n"
        echo -e "  ${Y}👤 အမည်     :${Z} $user   ${C}│${Z}  ${Y}📱 ဖုန်းအလုံးရေ :${Z} $limit"
        echo -e "  ${Y}⏳ သက်တမ်း :${Z} $exp ($days ရက်)"
        echo -e "\n  ${C}👇 Customer အား ပေးရန် Link 👇${Z}"
        echo -e "  ${M}${link}${Z}"
    else
        echo -e "${R}  ⚠️ System Error: JSON ပြင်၍မရပါ။${Z}"
    fi
    pause
}

# (၂) အကောင့်ဖျက်ခြင်း
del_user() {
    header
    echo -e "${R}  [-] အကောင့်ဖျက်ရန် ${Z}\n"
    show_account_table || { pause; return; }
    
    echo ""
    read -r -p "  ➔ ဖျက်လိုသော အကောင့်နံပါတ်ကို ရွေးပါ: " num
    num=$(echo "$num" | sed 's/[^0-9]//g')
    
    if [[ -n "$num" ]]; then
        user=$(sed -n "${num}p" "$DB" | awk '{print $1}')
        if [[ -n "$user" ]]; then
            jq --arg em "$user" 'del(.inbounds[0].settings.clients[] | select(.email == $em))' "$CFG" > tmp.json && mv tmp.json "$CFG"
            sed -i "${num}d" "$DB"
            systemctl restart xray
            echo -e "\n  ${G}✅ အကောင့် ($user) အား ဖျက်ပြီးပါပြီ။${Z}"
        else
            echo -e "${R}  ⚠️ နံပါတ်မှားနေပါသည်။${Z}"
        fi
    fi
    pause
}

# (၃) သက်တမ်းတိုးခြင်း
renew_user() {
    header
    echo -e "${Y}  [*] သက်တမ်းတိုးခြင်း / ရက်စွဲပြင်ခြင်း ${Z}\n"
    show_account_table || { pause; return; }
    
    echo ""
    read -r -p "  ➔ နံပါတ်ကို ရွေးပါ: " num
    num=$(echo "$num" | sed 's/[^0-9]//g')
    
    if [[ -n "$num" ]]; then
        user=$(sed -n "${num}p" "$DB" | awk '{print $1}')
        if [[ -n "$user" ]]; then
            echo -e "\n  ${C}(ဥပမာ: 30 သို့မဟုတ် 18-05-2026)${Z}"
            read -r -p "  ➔ ရက် (သို့) ရက်စွဲ ထည့်ပါ: " input
            input=$(echo "$input" | tr -d ' ')
            
            old_exp=$(grep "^$user " "$DB" | awk '{print $3}')
            uuid=$(grep "^$user " "$DB" | awk '{print $2}')
            limit=$(grep "^$user " "$DB" | awk '{print $4}')
            limit_val=${limit:-1}
            
            if [[ "$input" =~ ^[0-9]{1,2}-[0-9]{1,2}-[0-9]{4}$ ]]; then
                new_exp=$(date -d "$(echo "$input" | awk -F- '{print $3"-"$2"-"$1}')" +"%Y-%m-%d" 2>/dev/null)
            elif [[ "$input" =~ ^[0-9]+$ ]]; then
                new_exp=$(date -d "$old_exp +$input days" +"%Y-%m-%d" 2>/dev/null)
            fi
            
            if [[ -n "$new_exp" ]]; then
                sed -i "${num}d" "$DB"
                echo "$user $uuid $new_exp $limit_val" >> "$DB"
                echo -e "\n  ${G}✅ ရက်စွဲအသစ် : $new_exp${Z}"
            else
                echo -e "${R}  ⚠️ ပုံစံမှားနေပါသည်။${Z}"
            fi
        fi
    fi
    pause
}

# (၄) စာရင်းကြည့်ခြင်း
list_users() {
    header
    echo -e "  ${C}📋 VLESS အကောင့်စာရင်းများ ${Z}\n"
    show_account_table
    footer
    pause
}

# (၅) 🌐 Online Status
online_status() {
    header
    echo -e "  ${G}🌐 အကောင့်များ၏ Online & IP သုံးစွဲမှု ဇယား ${Z}\n"
    if [ ! -s "$DB" ]; then echo -e "${R}  ⚠️ အကောင့်မရှိသေးပါ။${Z}"; pause; return; fi

    echo -e "  ${C}╔════╦══════════════╦═════════════════╦════════════╗${Z}"
    echo -e "  ${C}║ ${Y}စဉ်${C} ║ ${Y}အမည်${C}         ║ ${Y}လက်ရှိအခြေအနေ${C}    ║ ${Y}IP သုံးစွဲမှု${C}  ║${Z}"
    echo -e "  ${C}╠════╬══════════════╬═════════════════╬════════════╣${Z}"

    t0=$(date +"%Y/%m/%d %H:%M")
    t1=$(date -d "1 minute ago" +"%Y/%m/%d %H:%M")

    active_lines=$(grep -E "$t0|$t1" "$LOG_FILE" 2>/dev/null | grep "accepted")

    local i=1
    while read -r user uuid exp limit; do
        limit_val=${limit:-1}
        ip_count=$(echo "$active_lines" | grep "email: $user" | awk '{print $3}' | cut -d: -f1 | sort | uniq | wc -l)
        
        printf "  ${C}║${Z} %-2s ${C}║${Z} %-12s ${C}║${Z}" "$i" "$user"
        
        if [ "$ip_count" -gt 0 ]; then
            if [ "$ip_count" -gt "$limit_val" ]; then
                echo -e "${R} ⚠️ Overlimit    ${C}║${Z}  ${R}$ip_count / $limit_val${Z} IP  ${C}║${Z}"
            else
                echo -e "${G} 🟢 Online       ${C}║${Z}  ${G}$ip_count / $limit_val${Z} IP  ${C}║${Z}"
            fi
        else
            echo -e "${Z} 🔴 Offline      ${C}║${Z}  ${Z}0 / $limit_val${Z} IP  ${C}║${Z}"
        fi
        i=$((i+1))
    done < "$DB"
    
    echo -e "  ${C}╚════╩══════════════╩═════════════════╩════════════╝${Z}"
    pause
}

# (၆) 🚫 Ban စာရင်းကြည့်ရန်
view_ban_log() {
    header
    echo -e "  ${R}🚫 ခိုးသုံး၍ အလိုအလျောက် ပိတ်ပင်ခံရသော မှတ်တမ်းများ ${Z}\n"
    if [ -s "$BAN_LOG" ]; then
        echo -e "  ${Y}$(tail -n 20 "$BAN_LOG")${Z}"
    else
        echo -e "  ${G}✅ လတ်တလော ခိုးသုံးသူ မရှိသေးပါ။${Z}"
    fi
    pause
}

# Main Loop
while true; do
    header
    echo -e "   ${G}[1]${Z} ➕ အကောင့်သစ်ဖန်တီးရန်"
    echo -e "   ${R}[2]${Z} ❌ အကောင့်ဖျက်ရန်"
    echo -e "   ${Y}[3]${Z} 🔄 သက်တမ်းတိုးရန် / ပြင်ရန်"
    echo -e "   ${C}[4]${Z} 📋 အကောင့်စာရင်းစစ်ရန်"
    echo -e "   ${M}[5]${Z} 🌐 Online & IP Limit စစ်ဆေးရန်"
    echo -e "   ${R}[6]${Z} 🚫 Auto-Ban မှတ်တမ်းကြည့်ရန်"
    echo -e "   ${B}[0]${Z} 🚪 ထွက်မည်"
    footer
    read -r -p "  ➔ ရွေးချယ်ရန် (0-6): " opt
    case "$opt" in
        1) add_user ;;
        2) del_user ;;
        3) renew_user ;;
        4) list_users ;;
        5) online_status ;;
        6) view_ban_log ;;
        0) clear; exit 0 ;;
        *) echo -e "${R}  ⚠️ မှားယွင်းနေပါသည်။${Z}"; sleep 1 ;;
    esac
done
