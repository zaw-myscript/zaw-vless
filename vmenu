#!/bin/bash
# ZAW VLESS CLI MENU (FINAL STABLE + ONLINE MONITOR)

trap ' ' INT
set +e

B="\e[1;34m"; G="\e[1;32m"; Y="\e[1;33m"; R="\e[1;31m"; C="\e[1;36m"; M="\e[1;35m"; Z="\e[0m"
CFG="/usr/local/etc/xray/config.json"
DB="/usr/local/etc/xray/users.txt"
IP=$(curl -s --max-time 5 ipv4.icanhazip.com || curl -s --max-time 5 ifconfig.me || echo "Your-IP")

pause() {
    echo -e "\n${C} ─────────────────────────────────────────────────${Z}"
    echo -e "${Y} ↩️  ရှေ့ဆက်ရန် Enter ခေါက်ပါ...${Z}"
    read -r
}

header() {
    clear
    echo -e "${C}╔═════════════════════════════════════════════════╗${Z}"
    echo -e "${C}║      ${Y}🌟 VLESS (WebSocket) MANAGER PRO 🌟${C}        ║${Z}"
    echo -e "${C}╠═════════════════════════════════════════════════╣${Z}"
}

footer() {
    echo -e "${C}╚═════════════════════════════════════════════════╝${Z}"
}

# (၁) အကောင့်သစ်ဖွင့်ခြင်း
add_user() {
    header
    echo -e "${G} ➕ အကောင့်သစ်ဖန်တီးခြင်း ${Z}\n"
    read -r -p " ➔ အကောင့်အမည် ထည့်ပါ: " user
    user=$(echo "$user" | sed 's/[^a-zA-Z0-9]//g')
    
    if [[ -z "$user" ]]; then echo -e "${R} ⚠️ အမည်မှားယွင်းနေပါသည်။${Z}"; pause; return; fi
    if grep -q "^$user " "$DB" 2>/dev/null; then echo -e "${R} ⚠️ ဤအမည်ရှိပြီးသားပါ။${Z}"; pause; return; fi
    
    read -r -p " ➔ သက်တမ်း (ရက်) ထည့်ပါ: " days
    days=$(echo "$days" | sed 's/[^0-9]//g')
    if [[ -z "$days" ]]; then echo -e "${R} ⚠️ ရက်အရေအတွက်မှားယွင်းနေပါသည်။${Z}"; pause; return; fi
    
    exp=$(date -d "+$days days" +"%Y-%m-%d" 2>/dev/null)
    uuid=$(cat /proc/sys/kernel/random/uuid 2>/dev/null || uuidgen)
    
    if jq --arg id "$uuid" --arg em "$user" '.inbounds[0].settings.clients += [{"id": $id, "email": $em}]' "$CFG" > tmp.json 2>/dev/null; then
        mv tmp.json "$CFG"
        echo "$user $uuid $exp" >> "$DB"
        systemctl restart xray
        
        link="vless://${uuid}@${IP}:80?type=ws&security=none&path=%2Fzawvless#${user}"
        
        header
        echo -e "${G} ✅ အကောင့်အောင်မြင်စွာ ဖွင့်ပြီးပါပြီ! ${Z}\n"
        echo -e "${Y} 👤 အမည်     :${Z} $user"
        echo -e "${Y} ⏳ သက်တမ်း :${Z} $exp ($days ရက်)"
        echo -e "\n${C} 👇 Customer အား ပေးရန် Link 👇${Z}"
        echo -e "${M}${link}${Z}"
    else
        echo -e "${R} ⚠️ System Error: JSON ပြင်၍မရပါ။${Z}"
    fi
    pause
}

# (၂) အကောင့်ဖျက်ခြင်း
del_user() {
    header
    echo -e "${R} ❌ အကောင့်ဖျက်ရန် ${Z}\n"
    if [ ! -s "$DB" ]; then echo -e "${R} ⚠️ အကောင့်မရှိသေးပါ။${Z}"; pause; return; fi
    
    echo -e "${Y} 📊 အကောင့်စာရင်း ${Z}"
    awk '{print "  ["NR"] " $1 " (" $3 ")"}' "$DB"
    echo ""
    read -r -p " ➔ ဖျက်လိုသော အကောင့်နံပါတ်ကို ရွေးပါ: " num
    num=$(echo "$num" | sed 's/[^0-9]//g')
    
    if [[ -n "$num" ]]; then
        user=$(sed -n "${num}p" "$DB" | awk '{print $1}')
        if [[ -n "$user" ]]; then
            jq --arg em "$user" 'del(.inbounds[0].settings.clients[] | select(.email == $em))' "$CFG" > tmp.json && mv tmp.json "$CFG"
            sed -i "${num}d" "$DB"
            systemctl restart xray
            echo -e "\n${G} ✅ အကောင့် ($user) အား ဖျက်ပြီးပါပြီ။${Z}"
        else
            echo -e "${R} ⚠️ နံပါတ်မှားနေပါသည်။${Z}"
        fi
    fi
    pause
}

# (၃) သက်တမ်းတိုးခြင်း
renew_user() {
    header
    echo -e "${G} 🔄 သက်တမ်းတိုးခြင်း ${Z}\n"
    if [ ! -s "$DB" ]; then echo -e "${R} ⚠️ အကောင့်မရှိသေးပါ။${Z}"; pause; return; fi
    
    awk '{print "  ["NR"] " $1 " (" $3 ")"}' "$DB"
    echo ""
    read -r -p " ➔ နံပါတ်ကို ရွေးပါ: " num
    num=$(echo "$num" | sed 's/[^0-9]//g')
    
    if [[ -n "$num" ]]; then
        user=$(sed -n "${num}p" "$DB" | awk '{print $1}')
        if [[ -n "$user" ]]; then
            echo -e "\n${C} (ဥပမာ: 30 သို့မဟုတ် 18-05-2026)${Z}"
            read -r -p " ➔ ရက် (သို့) ရက်စွဲ ထည့်ပါ: " input
            input=$(echo "$input" | tr -d ' ')
            
            old_exp=$(grep "^$user " "$DB" | awk '{print $3}')
            uuid=$(grep "^$user " "$DB" | awk '{print $2}')
            
            if [[ "$input" =~ ^[0-9]{1,2}-[0-9]{1,2}-[0-9]{4}$ ]]; then
                new_exp=$(date -d "$(echo "$input" | awk -F- '{print $3"-"$2"-"$1}')" +"%Y-%m-%d" 2>/dev/null)
            elif [[ "$input" =~ ^[0-9]+$ ]]; then
                new_exp=$(date -d "$old_exp +$input days" +"%Y-%m-%d" 2>/dev/null)
            fi
            
            if [[ -n "$new_exp" ]]; then
                sed -i "${num}d" "$DB"
                echo "$user $uuid $new_exp" >> "$DB"
                echo -e "\n${G} ✅ ရက်စွဲအသစ် : $new_exp${Z}"
            else
                echo -e "${R} ⚠️ ပုံစံမှားနေပါသည်။${Z}"
            fi
        fi
    fi
    pause
}

# (၄) စာရင်းကြည့်ခြင်း
list_users() {
    header
    echo -e "${C} 📋 VLESS အကောင့်စာရင်းများ ${Z}"
    echo -e " ─────────────────────────────────────────────────"
    printf "  %-5s %-12s %-15s %-10s\n" "စဉ်" "အမည်" "ကုန်ဆုံးရက်" "အခြေအနေ"
    echo -e " ─────────────────────────────────────────────────"
    today=$(date +%s)
    if [ -s "$DB" ]; then
        i=1
        while read -r user uuid exp; do
            exp_sec=$(date -d "$exp" +%s 2>/dev/null)
            status="${G}ပုံမှန်${Z}"; [[ $exp_sec -lt $today ]] && status="${R}သက်တမ်းလွန်${Z}"
            printf "  %-5s %-12s %-15s %-10b\n" "[$i]" "$user" "$exp" "$status"
            i=$((i+1))
        done < "$DB"
    else
        echo -e "${R}  အကောင့်မရှိသေးပါ။${Z}"
    fi
    footer
    pause
}

# (၅) Online စစ်ဆေးခြင်း (အသစ်ထပ်တိုးထားသည်)
check_online() {
    header
    echo -e "${G} 🌐 လက်ရှိချိတ်ဆက်အသုံးပြုနေသူများ (Online) ${Z}\n"
    
    # Port 80 သို့ ချိတ်ဆက်ထားသော IP များကို ရေတွက်ခြင်း
    online_count=$(ss -tn state established '( sport = :80 )' 2>/dev/null | grep -v "State" | awk '{print $5}' | cut -d: -f1 | sort | uniq | wc -l)
    
    if [[ "$online_count" -eq 0 || -z "$online_count" ]]; then
        echo -e "${R}  လက်ရှိတွင် ချိတ်ဆက်အသုံးပြုနေသူ မရှိပါ။${Z}"
    else
        echo -e "${C}  လက်ရှိ Online သုံးနေသူ (IP) အရေအတွက် :${Y} ${online_count} ယောက်${Z}"
    fi
    pause
}

# Main Loop
while true; do
    header
    echo -e "  ${G}[1]${Z} ➕ အကောင့်သစ်ဖန်တီးရန်"
    echo -e "  ${R}[2]${Z} ❌ အကောင့်ဖျက်ရန်"
    echo -e "  ${Y}[3]${Z} 🔄 သက်တမ်းတိုးရန် / ပြင်ရန်"
    echo -e "  ${C}[4]${Z} 📋 အကောင့်စာရင်းစစ်ရန်"
    echo -e "  ${M}[5]${Z} 🌐 လက်ရှိသုံးနေသူ (Online) ကြည့်ရန်"
    echo -e "  ${B}[0]${Z} 🚪 ထွက်မည်"
    footer
    read -r -p " ➔ ရွေးချယ်ရန် (0-5): " opt
    case "$opt" in
        1) add_user ;;
        2) del_user ;;
        3) renew_user ;;
        4) list_users ;;
        5) check_online ;;
        0) clear; exit 0 ;;
        *) echo -e "${R} ⚠️ မှားယွင်းနေပါသည်။${Z}"; sleep 1 ;;
    esac
done
