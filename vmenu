    echo -e "${C} ███████╗ █████╗ ██╗    ██╗    ███████╗ ██████╗██████╗ ██╗██████╗ ████████╗ ${Z}"
    echo -e "${C} ╚══███╔╝██╔══██╗██║    ██║    ██╔════╝██╔════╝██╔══██╗██║██╔══██╗╚══██╔══╝ ${Z}"
    echo -e "${C}   ███╔╝ ███████║██║ █╗ ██║    ███████╗██║     ██████╔╝██║██████╔╝   ██║    ${Z}"
    echo -e "${C}  ███╔╝  ██╔══██║██║███╗██║    ╚════██║██║     ██╔══██╗██║██╔═══╝    ██║    ${Z}"
