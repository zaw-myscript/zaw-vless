view_ban_log() {
    clear
    echo -e "\E[41;1;37m           🚫 V2RAY AUTO-BAN LOGS           \E[0m\n"
    if [ -s "$BAN_LOG" ]; then
        echo -e "  ${Y}$(tail -n 20 "$BAN_LOG")${Z}"
    else
        echo -e "  ${G}✅ လတ်တလော ခိုးသုံးသူ (Overlimit) မရှိသေးပါ။${Z}"
    fi
    pause
}

