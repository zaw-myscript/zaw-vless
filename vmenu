            read -r -p "➔ တိုးလိုသော ရက် (သို့) ရက်စွဲ ထည့်ပါ: " input
            input=$(echo "$input" | tr -d ' ')
            
            old_exp=$(grep "^$user " "$DB" | awk '{print $3}')
            uuid=$(grep "^$user " "$DB" | awk '{print $2}')
            limit=$(grep "^$user " "$DB" | awk '{print $4}')
            limit_val=${limit:-1}
            
