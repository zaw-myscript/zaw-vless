#!/bin/bash
# ZAW VLESS CLI MENU (PREMIUM HEADER + AUTO-BAN + AUTO-CLEAN EXPIRED FIXED)

trap ' ' INT
set +e

B="\e[1;34m"; G="\e[1;32m"; Y="\e[1;33m"; R="\e[1;31m"; C="\e[1;36m"; M="\e[1;35m"; Z="\e[0m"
CFG="/usr/local/etc/xray/config.json"
DB="/usr/local/etc/xray/users.txt"
LOG_DIR="/var/log/xray"
LOG_FILE="$LOG_DIR/access.log"
BAN_LOG="$LOG_DIR/limit_jail.log"

IP=$(cat /etc/IP 2>/dev/null || wget -qO- ipv4.icanhazip.com 2>/dev/null)

# === 🔴 AUTO-CLEAN (အကောင့်အလိုလိုဖျက်) စနစ် အသစ် 🔴 ===
clean_expired_users_silent() {
    if [ ! -s "$DB" ]; then return; fi
    local today_date=$(date +"%Y-%m-%d")
    local today_sec=$(date -d "$today_date" +%s)
    local changed=0

    local TMP_DB="/tmp/vless_users.tmp"
    local EXP_DB="/tmp/vless_exp.tmp"
    > "$TMP_DB"; > "$EXP_DB"

    while read -r user uuid exp limit; do
        exp_sec=$(date -d "$exp" +%s 2>/dev/null)
        if [[ -n "$exp_sec" && $exp_sec -lt $today_sec ]]; then
            echo "$user" >> "$EXP_DB"
            changed=1
        else
            echo "$user $uuid $exp $limit" >> "$TMP_DB"
        fi
    done < "$DB"

    if [ "$changed" -eq 1 ]; then
        cat "$TMP_DB" > "$DB"
        while read -r ex_user; do
            if jq --arg em "$ex_user" 'del(.inbounds[0].settings.clients[] | select(.email == $em))' "$CFG" > "$CFG.tmp" 2>/dev/null; then
                if [ -s "$CFG.tmp" ]; then mv "$CFG.tmp" "$CFG"; fi
            fi
        done < "$EXP_DB"
        systemctl restart xray
    fi
    rm -f "$TMP_DB" "$EXP_DB" "$CFG.tmp" 2>/dev/null
}

# === Log စနစ် ===
mkdir -p "$LOG_DIR"
touch "$LOG_FILE" "$BAN_LOG"
chown -R nobody:nogroup "$LOG_DIR" 2>/dev/null || chown -R nobody:nobody "$LOG_DIR" 2>/dev/null
chmod 644 "$LOG_FILE" "$BAN_LOG"

if [ -f "$CFG" ]; then
    if ! grep -q "\"access\":" "$CFG" || grep -q "/usr/local/etc/xray/access.log" "$CFG"; then
        if jq --arg log "$LOG_FILE" '.log.access = $log' "$CFG" > "$CFG.tmp" 2>/dev/null; then
            if [ -s "$CFG.tmp" ]; then mv "$CFG.tmp" "$CFG"; systemctl restart xray; sleep 1; fi
        fi
    fi
fi

# === Auto-Ban စနစ် ===
if [ ! -f "/usr/bin/vlimit" ] || grep -q "kicked" "/usr/bin/vlimit"; then
    cat > /usr/bin/vlimit << 'EOF'
#!/bin/bash
CFG="/usr/local/etc/xray/config.json"
DB="/usr/local/etc/xray/users.txt"
LOG="/var/log/xray/access.log"
BAN_LOG="/var/log/xray/limit_jail.log"

while true; do
    t0=$(date +"%Y/%m/%d %H:%M")
    log_data=$(grep "$t0" "$LOG" 2>/dev/null | grep "accepted")
    
    while read -r user uuid exp limit; do
        limit_val=${limit:-1}
        ip_count=$(echo "$log_data" | grep "email: $user" | awk '{print $3}' | cut -d: -f1 | sort | uniq | wc -l)
        
        if [ "$ip_count" -gt "$limit_val" ]; then
            if jq --arg em "$user" 'del(.inbounds[0].settings.clients[] | select(.email == $em))' "$CFG" > "$CFG.tmp" 2>/dev/null; then
                if [ -s "$CFG.tmp" ]; then mv "$CFG.tmp" "$CFG"; fi
            fi
            sed -i "/^$user /d" "$DB"
            systemctl restart xray
            echo "$(date +"%Y-%m-%d %H:%M:%S") - ❌ BANNED: $user (IPs: $ip_count / Limit: $limit_val)" >> "$BAN_LOG"
            sleep 5
        fi
    done < "$DB"
    sleep 30
done
EOF
    chmod +x /usr/bin/vlimit
    cat > /etc/systemd/system/vlimit.service << 'EOF'
[Unit]
Description=ZAW VLESS IP Limit Auto-Ban
After=network.target
[Service]
ExecStart=/usr/bin/vlimit
Restart=always
[Install]
WantedBy=multi-user.target
EOF
    systemctl daemon-reload
    systemctl enable --now vlimit
    systemctl restart vlimit
fi

