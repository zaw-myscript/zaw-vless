cfg['auth']['mode'] = 'passwords'
cfg['auth']['config'] = sorted(list(valid))
with open(cfile+'.tmp', 'w') as f: json.dump(cfg, f, indent=2)
os.rename(cfile+'.tmp', cfile)
" > /dev/null 2>&1
   systemctl restart zivpn.service > /dev/null 2>&1
}

