    echo -e "${M} ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ ${Z}"
    echo -e "   ${G}SERVER IP:${Z} ${Y}$IP${Z}  ${M}│${Z}  ${G}SYSTEM:${Z} ${Y}VLESS-WS${Z}  ${M}│${Z}  ${G}PORT:${Z} ${Y}80${Z}"
    echo -e "${M} ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ ${Z}"
