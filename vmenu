}

add_user() {
    clear
    echo -e "\E[44;1;37m         CREATE V2RAY (VLESS) ACCOUNT          \E[0m\n"
    read -r -p "◈ Username    : " user
    user=$(echo "$user" | sed 's/[^a-zA-Z0-9]//g')
    
    if [[ -z "$user" ]]; then echo -e "${R}  ⚠️ အမည်မှားယွင်းနေပါသည်။${Z}"; pause; return; fi
    if grep -q "^$user " "$DB" 2>/dev/null; then echo -e "${R}  ⚠️ ဤအမည်ရှိပြီးသားပါ။${Z}"; pause; return; fi
    
    read -r -p "◈ Expire Days : " days
    days=$(echo "$days" | sed 's/[^0-9]//g')
    if [[ -z "$days" ]]; then echo -e "${R}  ⚠️ ရက်အရေအတွက်မှားယွင်းနေပါသည်။${Z}"; pause; return; fi
    
    read -r -p "◈ IP Limit (ဖုန်းဘယ်နှစ်လုံးလဲ): " limit
    limit=$(echo "$limit" | sed 's/[^0-9]//g')
    [[ -z "$limit" ]] && limit=1
    
    exp=$(date -d "+$days days" +"%Y-%m-%d" 2>/dev/null)
    uuid=$(cat /proc/sys/kernel/random/uuid 2>/dev/null || uuidgen)
    
    # 🔴 FIX: Using Absolute Path + Size Check for JSON update 🔴
    if jq --arg id "$uuid" --arg em "$user" '.inbounds[0].settings.clients += [{"id": $id, "email": $em}]' "$CFG" > "$CFG.tmp" 2>/dev/null; then
        if [ -s "$CFG.tmp" ]; then
            mv "$CFG.tmp" "$CFG"
            echo "$user $uuid $exp $limit" >> "$DB"
            systemctl restart xray
            
            link="vless://${uuid}@${IP}:80?type=ws&security=none&path=%2Fzawvless#${user}"
            
            clear
            echo -e "\033[1;36m━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\033[0m"
            echo -e "\033[1;32m🚀Thu Ya Zaw🚀 V2Ray (Vless) အကောင့်ဖန်တီးပြီးပါပြီ\033[0m"
            echo -e "\033[1;36m━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\033[0m"
            echo -e "\033[1;33m◈📡 Host / IP   :⪧  \033[1;37m$IP\033[0m"
            echo -e "\033[1;33m◈🧸 Username    :⪧ \033[1;37m$user\033[0m"
            echo -e "\033[1;33m◈📱 IP Limit    :⪧ \033[1;37m$limit Devices\033[0m"
            echo -e "\033[1;33m◈🕰 Expire Date :⪧ \033[1;37m$exp\033[0m"
            echo -e "\n\033[1;36m   👇 Customer အား ပေးရန် Link 👇\033[0m"
            echo -e "\033[1;37m$link\033[0m"
            echo -e "\033[1;36m━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\033[0m"
        else
            echo -e "${R}  ⚠️ System Error: Config Update လုပ်ရာတွင် ဖိုင်ချို့ယွင်းသွားပါသည်။${Z}"
            rm -f "$CFG.tmp"
        fi
    else
        echo -e "${R}  ⚠️ System Error: JSON ပြင်၍မရပါ။ (jq command failed)${Z}"
    fi
    pause
}

del_user() {
    clear
    echo -e "\E[41;1;37m         DELETE V2RAY (VLESS) ACCOUNT          \E[0m\n"
    show_account_table || { pause; return; }
    
    echo ""
    read -r -p "➔ ဖျက်လိုသော အကောင့်နံပါတ်ကို ရွေးပါ : " num
    num=$(echo "$num" | sed 's/[^0-9]//g')
    
    if [[ -n "$num" ]]; then
        user=$(sed -n "${num}p" "$DB" | awk '{print $1}')
        if [[ -n "$user" ]]; then
            if jq --arg em "$user" 'del(.inbounds[0].settings.clients[] | select(.email == $em))' "$CFG" > "$CFG.tmp" 2>/dev/null; then
                if [ -s "$CFG.tmp" ]; then
                    mv "$CFG.tmp" "$CFG"
                    sed -i "${num}d" "$DB"
                    systemctl restart xray
                    echo -e "\n  ${G}✅ Account '$user' ကို အောင်မြင်စွာ ဖျက်ပစ်လိုက်ပါပြီ!${Z}"
                fi
            fi
        else
            echo -e "${R}  ⚠️ နံပါတ်မှားနေပါသည်။${Z}"
        fi
    fi
    pause
}

renew_user() {
